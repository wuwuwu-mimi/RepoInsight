# RepoInsight Git 克隆加速，可选
# GIT_CLONE_BASE_URL=https://your-mirror.example.com

# RepoInsight Embedding 配置
# 默认使用服务商提供的 embedding；命令行可用 --embedding-mode ollama 切到本地 Ollama
REPOINSIGHT_EMBEDDING_PROVIDER=service
REPOINSIGHT_EMBEDDING_MODEL=text-embedding-3-small
REPOINSIGHT_EMBEDDING_BASE_URL=https://api.openai.com/v1
REPOINSIGHT_EMBEDDING_API_KEY=your_embedding_api_key_here
REPOINSIGHT_EMBEDDING_TIMEOUT=30

# 本地 Ollama embedding 配置
REPOINSIGHT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
REPOINSIGHT_OLLAMA_BASE_URL=http://127.0.0.1:11434

# 兼容旧的 sentence-transformers 本地模式，可按需启用
# REPOINSIGHT_LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# REPOINSIGHT_LOCAL_EMBEDDING_MODEL_PATH=E:\models\bge-m3
# REPOINSIGHT_LOCAL_EMBEDDING_LOCAL_ONLY=1

# RepoInsight LLM 配置
# 优先读取 REPOINSIGHT_LLM_*，也兼容 OPENAI_* 变量名
REPOINSIGHT_LLM_PROVIDER=openai
REPOINSIGHT_LLM_MODEL=gpt-4o-mini
REPOINSIGHT_LLM_BASE_URL=https://api.openai.com/v1
REPOINSIGHT_LLM_API_KEY=your_api_key_here

# 可选参数
REPOINSIGHT_LLM_TIMEOUT=30
REPOINSIGHT_LLM_TEMPERATURE=0.2

# 若使用 Ollama，本地配置可参考：
# REPOINSIGHT_LLM_PROVIDER=ollama
# REPOINSIGHT_LLM_MODEL=qwen2.5:7b
# REPOINSIGHT_LLM_BASE_URL=http://127.0.0.1:11434
# REPOINSIGHT_LLM_API_KEY=ollama
