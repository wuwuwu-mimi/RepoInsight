# RepoInsight Git 克隆加速，可选
# GIT_CLONE_BASE_URL=https://your-mirror.example.com

# RepoInsight LLM 配置
# 优先读取 REPOINSIGHT_LLM_*，也兼容 OPENAI_* 变量名
REPOINSIGHT_LLM_PROVIDER=openai
REPOINSIGHT_LLM_MODEL=gpt-4o-mini
REPOINSIGHT_LLM_BASE_URL=https://api.openai.com/v1
REPOINSIGHT_LLM_API_KEY=your_api_key_here

# 可选参数
REPOINSIGHT_LLM_TIMEOUT=30
REPOINSIGHT_LLM_TEMPERATURE=0.2

# 若使用 Ollama，本地配置可参考：
# REPOINSIGHT_LLM_PROVIDER=ollama
# REPOINSIGHT_LLM_MODEL=qwen2.5:7b
# REPOINSIGHT_LLM_BASE_URL=http://127.0.0.1:11434
# REPOINSIGHT_LLM_API_KEY=ollama
